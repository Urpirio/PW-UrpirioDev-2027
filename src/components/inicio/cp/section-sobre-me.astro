---
const habilidades = [
  "Astro",
  "React",
  "TypeScript",
  "Node.js",
  "Tailwind CSS",
  "PostgreSQL",
];

const stats = [
  { valor: "3+", etiqueta: "Años de experiencia" },
  { valor: "20+", etiqueta: "Proyectos entregados" },
  { valor: "6", etiqueta: "Tecnologías principales" },
];
---

<section class="px-10 py-20 bg-neutral-950 text-white">
  <div class="mx-auto max-w-3xl text-center">
    <h2 class="text-4xl font-black text-[#38b000] sm:text-5xl">Sobre mí</h2>
    <div class="mx-auto mt-3 h-px w-10 bg-[#38b000]"></div>

    <p class="mt-4 text-sm text-neutral-400">
      Soy Urpirio, desarrollador web enfocado en construir sitios y
      aplicaciones rápidas, limpias y a medida. Me gusta llevar cada proyecto
      desde la idea hasta producción, cuidando tanto la experiencia de
      usuario como el rendimiento y la mantenibilidad del código.
    </p>

    <div class="mt-6 flex flex-wrap justify-center gap-2">
      {
        habilidades.map((habilidad) => (
          <span class="rounded-full bg-[#38b000]/10 px-3 py-1 text-xs font-medium text-[#38b000]">
            {habilidad}
          </span>
        ))
      }
    </div>
  </div>

  <div class="mx-auto mt-14 grid max-w-3xl grid-cols-1 gap-6 sm:grid-cols-3">
    {
      stats.map((stat) => (
        <div class="rounded-3xl border border-neutral-800 p-6 text-center">
          <p class="text-3xl font-black text-[#38b000]">{stat.valor}</p>
          <p class="mt-1 text-sm text-neutral-400">{stat.etiqueta}</p>
        </div>
      ))
    }
  </div>

  <div class="mt-10 flex justify-center">
    <a
      href="/sobre-me"
      class="rounded-full border border-neutral-700 px-6 py-3 font-medium text-neutral-200 transition-colors hover:border-[#38b000] hover:text-[#38b000]"
    >
      Ver más
    </a>
  </div>
</section>
